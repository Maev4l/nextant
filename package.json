{
  "name": "@isnan/nextant",
  "version": "0.1.0",
  "description": "Web/PWA navigation library for React - react-navigation for the browser",
  "type": "module",
  "main": "./dist/nextant.cjs",
  "module": "./dist/nextant.js",
  "exports": {
    ".": {
      "import": "./dist/nextant.js",
      "require": "./dist/nextant.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp src/styles/navigation.css dist/styles.css",
    "lint": "eslint src/ example/",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-navigation/core": "7.16.1",
    "@react-navigation/routers": "7.5.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "fast-deep-equal": "3.1.3",
    "lucide-react": "0.468.0",
    "nanoid": "5.0.9",
    "tailwind-merge": "2.6.0"
  },
  "peerDependencies": {
    "react": "18.0.0",
    "react-dom": "18.0.0",
    "tailwindcss": "3.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "2.1.8",
    "eslint": "9.17.0",
    "eslint-plugin-react": "7.37.5",
    "globals": "15.14.0",
    "jsdom": "25.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "vite": "6.0.6",
    "vitest": "2.1.8"
  },
  "keywords": [
    "react",
    "navigation",
    "router",
    "pwa",
    "web"
  ],
  "author": "isnan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/isnan/nextant.git"
  }
}
